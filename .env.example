# postgres DSN; real value in the cluster's memo-syncer-env secret.
# needed locally only when running the syncer against a real DB instead of `docker compose up postgres`.
DATABASE_URL=

# redis URL for char_id cache + rate limiter; real value in memo-syncer-env.
# needed locally only when running against a real Redis instead of `docker compose up redis`.
REDIS_URL=

# X-Auth-Key for POSTs to memo-server /fight/; real value in memo-syncer-env.
# needed locally when uploading to api.sumemo.dev from a dev box.
MEMO_KEY=

# FFLogs OAuth client used when the donated logs_keys table is empty; real value in memo-syncer-env.
# both must be set or neither — startup logs warn and exits if no keys are usable.
GRAPH_ID=
GRAPH_SECRET=

# log floor: trace / debug / info / warn / error. defaults to info. set to debug locally for verbose worker / pool output.
LOG_LEVEL=

# environment tag baked into JSON log fields and /status. prod in cluster; dev locally.
MEMO_ENV=

# version + build are baked in by CI via docker --build-arg.
# set locally only when reproducing a /status response.
MEMO_VERSION=
MEMO_BUILD=

# override the default 8 worker goroutines. tune up only when the donated keypool can absorb more concurrent FFLogs traffic.
SYNCER_WORKERS=

# set to "true" for a single boot to clear members.logs_sync_time and force a full re-sync. unset afterwards.
RESET_STALE_SYNC=
